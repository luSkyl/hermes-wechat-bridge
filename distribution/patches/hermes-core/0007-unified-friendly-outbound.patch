+
+
+def ensure_friendly_outbound(
+    text: Any,
+    *,
+    category: str = "status",
+    config: Mapping[str, Any] | None = None,
+) -> str:
+    raw = str(text or "").strip()
+    if not raw:
+        return render_empty_response_notice(config)
+    clean = _sanitize_user_visible(raw).strip()
+    if looks_like_ordinary_reply_card(clean) or _looks_like_friendly_status_card(clean):
+        return clean
+    if _contains_raw_error(raw):
+        return render_runtime_issue_notice(raw, config)
+    if category == "assistant":
+        return render_ordinary_reply(clean, config)
+    if category == "status":
+        return friendly_card(
+            "🧭 当前进展",
+            action="已把系统状态转换成可读说明",
+            result=clean,
+            impact="你能看到当前处理进展，不需要阅读内部英文日志或调试字段",
+            boundary="不会展示密钥、接口地址、堆栈或原始供应商错误",
+            next_step="我会继续推进；如果还没完成，会按节奏继续反馈。",
+        )
+    return clean
+
+
+def _contains_raw_error(text: Any) -> bool:
+    lowered = str(text or "").lower()
+    return any(marker in lowered for marker in RAW_ERROR_MARKERS)
+
+
+def _looks_like_friendly_status_card(text: str) -> bool:
+    clean = str(text or "").strip()
+    if not clean or CARD_DIVIDER not in clean:
+        return False
+    return clean.startswith((
+        "⚠️",
+        "🧭",
+        "🌿",
+        "📌",
+        "♻️",
+        "📬",
+        "📭",
+        "🧩",
+        "🛡️",
+    ))
+
+
+def _public_runtime_issue_reason(error: str) -> str:
+    lowered = str(error or "").lower()
+    if any(token in lowered for token in ("invalid api key", "invalid_api_key", "api key", "authentication", "unauthorized", "http 401")):
+        return "模型服务鉴权没有通过；密钥、接口返回和供应商原文已隐藏。"
+    if "rate limited" in lowered or "http 429" in lowered or "ret=-2" in lowered or "errcode=-2" in lowered:
+        return "当前通道触发限流或发送保护；我会暂停刷屏，并等待可用窗口再继续。"
+    if "trying fallback" in lowered or "fallback" in lowered:
+        return "主通道没有顺利完成，我正在切换备用通道或保留现场。"
+    if "timeout" in lowered or "timed out" in lowered:
+        return "上游响应超时；我已停止本轮继续等待，避免你长时间看不到结果。"
+    if "traceback" in lowered or "runtimeerror" in lowered:
+        return "内部执行链路遇到异常；堆栈和调试细节已转入本地日志。"
+    return "内部技术细节已隐藏；当前只保留对你有用的处理状态。"
+
