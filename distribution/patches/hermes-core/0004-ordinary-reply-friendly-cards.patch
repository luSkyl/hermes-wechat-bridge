 RAW_ERROR_MARKERS = (
@@ -223,6 +252,88 @@ def render_persona_reply(text: str, config: Mapping[str, Any] | None = None) ->
     return None
 
 
+def render_ordinary_reply(text: str, config: Mapping[str, Any] | None = None) -> str:
+    persona = get_persona(config)
+    clean_text = _sanitize_user_visible(text).strip()
+    if looks_like_ordinary_reply_card(clean_text):
+        return clean_text
+    urgent = _looks_urgent(clean_text)
+    title = "⚠️ 先确认安全" if urgent else "📍 先说结论"
+    intro = f"我是「{persona.display_name}」，先帮你把重点稳住。" if urgent else persona.greeting_text()
+    summary, detail = _split_reply_summary_and_detail(clean_text)
+    closing = (
+        "先按安全优先处理；你继续发现场情况，我再帮你一起判断。"
+        if urgent
+        else "如果你愿意，我可以继续帮你拆成步骤、风险点或执行清单 🌿"
+    )
+    return _render_reply_card(
+        title=title,
+        intro=intro,
+        summary=summary,
+        detail=detail,
+        closing=closing,
+        urgent=urgent,
+    )
+
+
+def _render_reply_card(*, title: str, intro: str, summary: str, detail: str, closing: str, urgent: bool) -> str:
+    detail_title = "🧭 关键信息" if urgent else "✨ 重点细节"
+    action_title = "📌 下一步" if urgent else "🌿 接下来"
+    return "\n".join((title, CARD_DIVIDER, intro, "", summary, "", detail_title, detail, "", action_title, closing))
+
+
+def _split_reply_summary_and_detail(text: str) -> tuple[str, str]:
+    lines = [_normalize_reply_line(line) for line in str(text or "").replace("\r\n", "\n").replace("\r", "\n").split("\n")]
+    lines = [line for line in lines if line]
+    if not lines:
+        return "我已收到你的消息。", "暂无更多细节。"
+    summary = lines[0]
+    if len(summary) > 120:
+        summary = summary[:117].rstrip() + "…"
+    if len(lines) == 1:
+        detail = lines[0] if lines[0] != summary else "我已经把核心内容放在上面；如果你需要，我可以继续展开原因、步骤或风险点。"
+        return summary, detail
+    detail_source = lines[1:]
+    if lines[0] != summary:
+        detail_source = lines
+    detail_lines = [_format_reply_detail_line(line) for line in detail_source]
+    return summary, "\n".join(detail_lines)
+
+
+def _normalize_reply_line(line: str) -> str:
+    clean = str(line or "").strip()
+    if re.fullmatch(r"\|?\s*:?-{3,}:?\s*(?:\|\s*:?-{3,}:?\s*)+\|?", clean):
+        return CARD_DIVIDER
+    return clean
+
+
+def _format_reply_detail_line(line: str) -> str:
+    if line == CARD_DIVIDER or _looks_structured_reply_line(line):
+        return line
+    return f"• {line}"
+
+
+def _looks_structured_reply_line(line: str) -> bool:
+    clean = str(line or "").lstrip()
+    if clean.startswith(("- ", "* ", "• ", "· ", ">", "#", "```", "【")):
+        return True
+    if re.match(r"^\d{1,2}[.)、]\s*\S", clean):
+        return True
+    if re.match(r"^[^\w\s]{1,4}\s+\S", clean):
+        return True
+    return clean.endswith(("：", ":"))
+
+
+def _looks_urgent(text: str) -> bool:
+    lowered = str(text or "").lower()
+    return any(keyword in lowered for keyword in URGENT_KEYWORDS)
+
+
+def looks_like_ordinary_reply_card(text: str) -> bool:
+    clean = str(text or "").strip()
+    return CARD_DIVIDER in clean and clean.startswith(ORDINARY_REPLY_CARD_TITLES)
+
+
