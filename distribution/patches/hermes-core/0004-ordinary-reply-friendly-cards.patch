+def test_ordinary_reply_uses_card_layout_and_urgent_style():
+    normal = render_ordinary_reply(
+        "先做结论\n然后补充原因\n|---|---|\n最后给下一步",
+        {"friendly": {"persona": {"display_name": "贾维斯"}}},
+    )
+    urgent = render_ordinary_reply(
+        "现在在地震区，请给我安全建议",
+        {"friendly": {"persona": {"display_name": "贾维斯"}}},
+    )
+
+    assert normal.startswith("📍 先说结论")
+    assert "────────────────────────" in normal
+    assert "|---|---|" not in normal
+    assert "我是「贾维斯」，你的随身执行伙伴 😊～" in normal
+    assert "✨ 重点细节" in normal
+    assert "然后补充原因" in normal
+    assert "最后给下一步" in normal
+    assert "🌿 接下来" in normal
+    assert looks_like_ordinary_reply_card(normal)
+    assert render_ordinary_reply(normal) == normal
+    assert urgent.startswith("⚠️ 先确认安全")
+    assert "贾维斯" in urgent
+    assert "😊" not in urgent
+
+    assert not looks_like_ordinary_reply_card("【状态】\n动作｜已处理")
