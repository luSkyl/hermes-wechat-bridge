@@ -442,6 +442,54 @@ def test_load_pool_falls_back_to_os_environ_when_dotenv_empty(tmp_path, monkeypa
     assert entry.access_token == "sk-or-from-runtime-env"
 
 
+def test_custom_pool_seeds_key_env_and_prunes_stale_config_entry(tmp_path, monkeypatch):
+    hermes_home = tmp_path / "hermes"
+    hermes_home.mkdir()
+    monkeypatch.setenv("HERMES_HOME", str(hermes_home))
+    monkeypatch.setenv("OPENAI_API_KEY", "sk-fresh-from-env")
+    (hermes_home / ".env").write_text("OPENAI_API_KEY=sk-fresh-from-dotenv\n")
+    (hermes_home / "config.yaml").write_text(
+        "custom_providers:\n"
+        "- name: ciii_codex\n"
+        "  base_url: https://codex.ciii.club\n"
+        "  key_env: OPENAI_API_KEY\n"
+    )
+    _write_auth_store(
+        tmp_path,
+        {
+            "version": 1,
+            "providers": {},
+            "credential_pool": {
+                "custom:ciii_codex": [
+                    {
+                        "id": "stale",
+                        "label": "ciii_codex",
+                        "auth_type": "api_key",
+                        "priority": 0,
+                        "source": "config:ciii_codex",
+                        "access_token": "sk-stale-from-old-inline-config",
+                        "base_url": "https://codex.ciii.club",
+                    }
+                ]
+            },
+        },
+    )
+
+    from agent.credential_pool import load_pool
+
+    pool = load_pool("custom:ciii_codex")
+    entries = pool.entries()
+
+    assert len(entries) == 1
+    assert entries[0].source == "env:OPENAI_API_KEY"
+    assert entries[0].access_token == "sk-fresh-from-dotenv"
+    assert entries[0].priority == 0
+
+    auth_payload = json.loads((hermes_home / "auth.json").read_text())
+    persisted = auth_payload["credential_pool"]["custom:ciii_codex"]
+    assert [entry["source"] for entry in persisted] == ["env:OPENAI_API_KEY"]
+
+
