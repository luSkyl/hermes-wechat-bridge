+def _divider_content_length(parts: Iterable[Any]) -> int:
+    total = 0
+    for part in parts:
+        if part is None:
+            continue
+        if isinstance(part, (list, tuple, set)):
+            total += _divider_content_length(part)
+            continue
+        total += len(str(part).strip())
+    return total
+
+
+def card_divider_for(*parts: Any) -> str:
+    """Return a WeChat-friendly divider length based on card content size."""
+    total = _divider_content_length(parts)
+    if total <= 80:
+        length = 12
+    elif total <= 180:
+        length = 16
+    elif total <= 360:
+        length = 20
+    else:
+        length = CARD_DIVIDER_MAX_LENGTH
+    return CARD_DIVIDER_CHAR * length
+
+
+def is_card_divider_line(line: Any) -> bool:
+    return bool(_CARD_DIVIDER_RE.fullmatch(str(line or "").strip()))
+
+
+def contains_card_divider(text: Any) -> bool:
+    return any(is_card_divider_line(line) for line in str(text or "").splitlines())
