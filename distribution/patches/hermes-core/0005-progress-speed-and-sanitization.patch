+    if "user profile" in lowered or "preference" in lowered:
+        return "\u540e\u7eed\u56de\u590d\u4f1a\u66f4\u8d34\u5408\u4f60\u7684\u504f\u597d\uff0c\u4f46\u4e0d\u4f1a\u8986\u76d6\u4f60\u7684\u5373\u65f6\u6307\u4ee4"
+    if "memory" in lowered:
+        return "\u540e\u7eed\u76f8\u5173\u4efb\u52a1\u4f1a\u53c2\u8003\u8fd9\u6761\u957f\u671f\u8bb0\u5fc6\uff0c\u51cf\u5c11\u91cd\u590d\u89e3\u91ca"
+    return "\u540e\u7eed\u76f8\u4f3c\u573a\u666f\u4f1a\u53c2\u8003\u8fd9\u6b21\u6c89\u6dc0\uff0c\u4f46\u4f60\u968f\u65f6\u53ef\u4ee5\u7ea0\u6b63"
+
