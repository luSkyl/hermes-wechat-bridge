+def _sanitize_raw_error_text(text: str) -> str:
+    lines = [line.strip() for line in str(text or "").replace("\r\n", "\n").replace("\r", "\n").split("\n")]
+    kept: list[str] = []
+    hidden = False
+    for line in lines:
+        if not line:
+            continue
+        lowered = line.lower()
+        if any(marker in lowered for marker in RAW_ERROR_MARKERS):
+            hidden = True
+            prefix = _text_before_first_marker(line, RAW_ERROR_MARKERS).strip(" ：:，,。.;；|-—")
+            if prefix and not any(marker in prefix.lower() for marker in RAW_ERROR_MARKERS):
+                kept.append(prefix)
+            continue
+        if re.search(r"\b(?:file|line)\b.*\.(?:py|js|ts|tsx|go|rs)", lowered):
+            hidden = True
+            continue
+        if len(line) > 220:
+            hidden = True
+            line = line[:217].rstrip() + "…"
+        kept.append(line)
+    if kept:
+        body = "\n".join(dict.fromkeys(kept[:6]))
+        if hidden:
+            return f"{body}\n内部技术细节已隐藏，聊天里只保留可操作信息。"
+        return body
+    return "内部技术细节已隐藏；当前没有提取到可靠的可操作结论，我会继续从日志里定位原因。"
+
+
+def _text_before_first_marker(text: str, markers: Sequence[str]) -> str:
+    lowered = str(text or "").lower()
+    positions = [lowered.find(marker) for marker in markers if marker and lowered.find(marker) > 0]
+    if not positions:
+        return ""
+    return str(text or "")[: min(positions)]
+
+
+def _background_review_summary(message: str | None) -> str:
+    text = str(message or "").strip()
+    text = re.sub(r"^\s*[\U0001f4be\U0001f9e0]\s*", "", text)
+    match = re.search(r"self-improvement\s+review\s*:\s*(.+)$", text, flags=re.IGNORECASE)
+    if match:
+        text = match.group(1)
+    text = re.sub(r"\s+", " ", text).strip(" .\u3002")
+    return text or "Background review updated"
+
+
+def _background_review_parts(summary: str) -> list[str]:
+    return [
+        part.strip(" .\u3002")
+        for part in re.split(r"\s*(?:\u00b7|\uff1b|;|\uff0c|,)\s*", str(summary or ""))
+        if part.strip(" .\u3002")
+    ]
+
+
+def _background_review_result(summary: str) -> str:
+    rendered = [_background_review_part_result(part) for part in _background_review_parts(summary)]
+    rendered = list(dict.fromkeys(item for item in rendered if item))
+    if not rendered:
+        return "\u5df2\u66f4\u65b0\u4e00\u6761\u53ef\u590d\u7528\u8bb0\u5f55\u3002"
+    return "\uff1b".join(rendered) + "\u3002"
+
+
+def _background_review_part_result(part: str) -> str:
+    lowered = part.lower()
+    skill_match = re.search(r"skill\s+['\"]([^'\"]+)['\"]", part, flags=re.IGNORECASE)
+    skill_name = skill_match.group(1).strip() if skill_match else ""
+    if "user profile" in lowered or lowered.startswith("user "):
+        return "\u7528\u6237\u753b\u50cf\u5df2\u66f4\u65b0"
+    if "memory" in lowered or "memories" in lowered:
+        return "\u957f\u671f\u8bb0\u5fc6\u5df2\u66f4\u65b0"
+    if "skill" in lowered:
+        if "created" in lowered or "added" in lowered:
+            action = "\u6280\u80fd\u5df2\u65b0\u589e"
+        else:
+            action = "\u6280\u80fd\u5df2\u66f4\u65b0"
+        return f"{action}\uff1a{skill_name}" if skill_name else action
+    if "preference" in lowered or "preferences" in lowered:
+        return "\u957f\u671f\u504f\u597d\u5df2\u66f4\u65b0"
+    safe = _sanitize_user_visible(part)
+    return safe if safe else "\u81ea\u6211\u5347\u7ea7\u8bb0\u5f55\u5df2\u66f4\u65b0"
+
+
+def _background_review_impact(summary: str) -> str:
+    lowered = str(summary or "").lower()
