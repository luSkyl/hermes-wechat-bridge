+def _compact_message_preview(content: str, limit: int = 1200) -> str:
+    rendered = str(content or "").strip()
+    if not rendered:
+        return "任务已完成，但没有返回可展示内容。"
+    if len(rendered) <= limit:
+        return rendered
+    return rendered[: max(0, limit - 3)].rstrip() + "..."
