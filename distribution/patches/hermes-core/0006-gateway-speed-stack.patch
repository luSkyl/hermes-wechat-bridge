diff --git a/gateway/speed_router.py b/gateway/speed_router.py
new file mode 100644
index 000000000..f9fa42ced
--- /dev/null
+++ b/gateway/speed_router.py
@@ -0,0 +1,294 @@
+"""Lightweight speed routing for gateway turns.
+
+The router keeps user-visible chats responsive by separating simple, no-tool
+conversation from full agent execution.  It is intentionally dependency-light so
+the gateway can call it before constructing an ``AIAgent`` and loading tool
+schemas.
+"""
+
+from __future__ import annotations
+
+import re
+from dataclasses import dataclass
+from typing import Any, Mapping, Sequence
+
+
+DEFAULT_FAST_CHAT_MAX_CHARS = 420
+DEFAULT_FAST_CHAT_MAX_ITERATIONS = 4
+DEFAULT_FIRST_ACK_SECONDS = 2.0
+DEFAULT_PROGRESS_FIRST_AFTER_SECONDS = 45.0
+
+
+URGENT_KEYWORDS = (
+    "地震",
+    "余震",
+    "震区",
+    "灾区",
+    "避险",
+    "撤离",
+    "报警",
+    "急救",
+    "危险",
+    "紧急",
+    "安全",
+    "受伤",
+    "火灾",
+    "洪水",
+    "台风",
+    "坍塌",
+    "泄漏",
+    "earthquake",
+    "aftershock",
+    "emergency",
+    "danger",
+    "urgent",
+    "evacuate",
+    "evacuation",
+)
+
+
+TOOL_REQUIRED_KEYWORDS = (
+    "落地",
+    "实现",
+    "修复",
+    "修改",
+    "改一下",
+    "直接操作",
+    "执行",
+    "运行",
+    "测试",
+    "构建",
+    "编译",
+    "重启",
+    "提交",
+    "推送",
+    "push",
+    "commit",
+    "github",
+    "git ",
+    "仓库",
+    "项目",
+    "代码",
+    "文件",
+    "目录",
+    "日志",
+    "报错",
+    "错误",
+    "bug",
+    "根因",
+    "排查",
+    "检查",
+    "搜索",
+    "查询",
+    "查一下",
+    "最新",
+    "今天",
+    "明天",
+    "提醒",
+    "定时",
+    "日程",
+    "照片",
+    "图片",
+    "截图",
+    "http://",
+    "https://",
+)
+
+
+SAFE_FAST_HINTS = (
+    "你觉得",
+    "怎么看",
+    "什么意思",
+    "怎么理解",
+    "解释一下",
+    "帮我润色",
+    "排版",
+    "友好",
+    "模板",
+    "方案",
+    "建议",
+    "普通消息",
+)
+
+
+_PATH_RE = re.compile(r"(?:[A-Za-z]:\\|/[^\s]+/|\.\.?[/\\])")
+_CODE_BLOCK_RE = re.compile(r"```|`[^`]+`")
+
+
+@dataclass(frozen=True)
+class SpeedRoute:
+    """Resolved execution profile for one gateway turn."""
+
+    name: str
+    reason: str
+    enabled_toolsets: tuple[str, ...] | None = None
+    disabled_toolsets: tuple[str, ...] | None = None
+    max_iterations: int | None = None
+    reasoning_effort: str | None = None
+    first_ack_seconds: float | None = None
+    progress_first_after_seconds: float | None = None
+
+    @property
+    def is_fast_chat(self) -> bool:
+        return self.name in {"fast_chat", "safety_fast"}
+
+    @property
+    def wants_first_ack(self) -> bool:
+        return self.first_ack_seconds is not None and self.first_ack_seconds >= 0
+
+
+def resolve_speed_route(
+    text: str,
+    *,
+    config: Mapping[str, Any] | None = None,
+    command: str | None = None,
+    has_media: bool = False,
+    is_followup: bool = False,
+) -> SpeedRoute:
+    """Return the lightest safe execution route for a gateway message."""
+
+    speed_cfg = _speed_config(config)
+    if not _truthy(speed_cfg.get("enabled"), True):
+        return _agent_route("speed_disabled", speed_cfg)
+
+    clean = str(text or "").strip()
+    lowered = clean.lower()
+    if not clean:
+        return _agent_route("empty_message", speed_cfg)
+    if command or clean.startswith("/"):
+        return _agent_route("slash_command", speed_cfg)
+    if has_media:
+        return _agent_route("media_message", speed_cfg)
+    if _has_urgent_keyword(lowered):
+        return _fast_route("safety_fast", "urgent_safety", speed_cfg)
+    if not _truthy(speed_cfg.get("fast_chat_enabled"), True):
+        return _agent_route("fast_chat_disabled", speed_cfg)
+    if is_followup and not _truthy(speed_cfg.get("fast_chat_for_followups"), True):
+        return _agent_route("conversation_followup", speed_cfg)
+    if len(clean) > _int_value(speed_cfg.get("fast_chat_max_chars"), DEFAULT_FAST_CHAT_MAX_CHARS):
+        return _agent_route("message_too_long", speed_cfg)
+    if _looks_tool_required(clean, lowered):
+        return _agent_route("tool_required", speed_cfg)
+    if _looks_safe_fast_chat(clean, lowered):
+        return _fast_route("fast_chat", "safe_ordinary_chat", speed_cfg)
+    return _agent_route("uncertain_intent", speed_cfg)
+
+
+def apply_speed_route_to_reasoning(
+    reasoning_config: dict | None,
+    route: SpeedRoute,
+) -> dict | None:
+    """Apply a route-specific reasoning effort without importing heavy modules."""
+
+    if not route.reasoning_effort:
+        return reasoning_config
+    try:
+        from hermes_constants import parse_reasoning_effort
+
+        parsed = parse_reasoning_effort(route.reasoning_effort)
+    except Exception:
+        parsed = None
+    return parsed if parsed is not None else reasoning_config
+
+
+def _speed_config(config: Mapping[str, Any] | None) -> Mapping[str, Any]:
+    if not isinstance(config, Mapping):
+        return {}
+    speed = config.get("speed")
+    return speed if isinstance(speed, Mapping) else {}
+
+
+def _agent_route(reason: str, speed_cfg: Mapping[str, Any]) -> SpeedRoute:
+    first_ack = _float_value(
+        speed_cfg.get("complex_first_ack_seconds"),
+        DEFAULT_FIRST_ACK_SECONDS,
+    )
+    if not _truthy(speed_cfg.get("first_ack_enabled"), True):
+        first_ack = None
+    return SpeedRoute(
+        name="agent",
+        reason=reason,
+        first_ack_seconds=first_ack,
+        progress_first_after_seconds=_float_value(
+            speed_cfg.get("progress_first_after"),
+            DEFAULT_PROGRESS_FIRST_AFTER_SECONDS,
+        ),
+    )
+
+
+def _fast_route(name: str, reason: str, speed_cfg: Mapping[str, Any]) -> SpeedRoute:
+    raw_toolsets = speed_cfg.get("fast_chat_toolsets", [])
+    toolsets = _string_tuple(raw_toolsets)
+    return SpeedRoute(
+        name=name,
+        reason=reason,
+        enabled_toolsets=toolsets,
+        max_iterations=_int_value(
+            speed_cfg.get("fast_chat_max_iterations"),
+            DEFAULT_FAST_CHAT_MAX_ITERATIONS,
+        ),
+        reasoning_effort=str(speed_cfg.get("fast_chat_reasoning_effort") or "low"),
+        progress_first_after_seconds=_float_value(
+            speed_cfg.get("progress_first_after"),
+            DEFAULT_PROGRESS_FIRST_AFTER_SECONDS,
+        ),
+    )
+
+
+def _looks_tool_required(text: str, lowered: str) -> bool:
+    if _PATH_RE.search(text) or _CODE_BLOCK_RE.search(text):
+        return True
+    return any(keyword in lowered for keyword in TOOL_REQUIRED_KEYWORDS)
+
+
+def _looks_safe_fast_chat(text: str, lowered: str) -> bool:
+    if any(keyword in lowered for keyword in SAFE_FAST_HINTS):
+        return True
+    # Short conversational turns that do not ask Hermes to inspect or operate on
+    # external state are safe to answer without tool schemas.
+    if len(text) <= 80 and text.endswith(("？", "?")):
+        return True
+    return False
+
+
+def _has_urgent_keyword(lowered: str) -> bool:
+    return any(keyword in lowered for keyword in URGENT_KEYWORDS)
+
+
+def _truthy(value: Any, default: bool) -> bool:
+    if value is None:
+        return default
+    if isinstance(value, bool):
+        return value
+    return str(value).strip().lower() not in {"", "0", "false", "no", "off", "none"}
+
+
+def _int_value(value: Any, default: int) -> int:
+    try:
+        return max(1, int(value))
+    except (TypeError, ValueError):
+        return default
+
+
+def _float_value(value: Any, default: float | None) -> float | None:
+    if value is None:
+        return default
+    try:
+        number = float(value)
+    except (TypeError, ValueError):
+        return default
+    if number < 0:
+        return None
+    return number
+
+
+def _string_tuple(value: Any) -> tuple[str, ...]:
+    if value is None:
+        return ()
+    if isinstance(value, str):
+        items: Sequence[Any] = [part.strip() for part in value.split(",")]
+    elif isinstance(value, Sequence):
+        items = value
+    else:
+        return ()
+    return tuple(str(item).strip() for item in items if str(item).strip())
