+def render_task_started(
+    goal: str,
+    *,
+    next_feedback_seconds: int | float = 45,
+    config: Mapping[str, Any] | None = None,
+) -> str:
+    """Render a useful first acknowledgement for complex/long-running turns."""
+
+    persona = get_persona(config)
