+    throw new Error(await friendlyApiErrorMessage(res))
   }
 
   return res.json()
 }
 
+async function friendlyApiErrorMessage(res: Response): Promise<string> {
+  const text = await res.text().catch(() => '')
+  const payloadMessage = extractFriendlyErrorPayload(text)
+  return friendlyNoticeText(payloadMessage || text || res.statusText, DEFAULT_API_ERROR)
+}
+
+function extractFriendlyErrorPayload(text: string): string {
+  if (!text) return ''
+  try {
+    const payload = JSON.parse(text) as { userMessage?: unknown; error?: unknown; message?: unknown }
+    if (typeof payload.userMessage === 'string') return payload.userMessage
+    if (typeof payload.error === 'string') return payload.error
+    if (typeof payload.message === 'string') return payload.message
+  } catch {
+    return ''
+  }
+  return ''
+}
