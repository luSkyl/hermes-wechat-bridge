diff --git a/packages/client/src/utils/semantic-message.ts b/packages/client/src/utils/semantic-message.ts
new file mode 100644
index 0000000..fa8cac9
--- /dev/null
+++ b/packages/client/src/utils/semantic-message.ts
@@ -0,0 +1,393 @@
+export type SemanticMessageTone = 'success' | 'warning' | 'danger' | 'info'
+
+export interface SemanticField {
+  label: string
+  value: string
+  mono?: boolean
+  href?: string
+}
+
+export interface SemanticItem {
+  title: string
+  id?: string
+  fields: SemanticField[]
+}
+
+export interface SemanticAction {
+  label: string
+  kind: 'jobs' | 'stop' | 'copy' | 'send'
+  href?: string
+  value?: string
+}
+
+export interface SemanticMessageCard {
+  type: 'cron' | 'review' | 'approval'
+  tone: SemanticMessageTone
+  icon: string
+  status: string
+  title: string
+  subtitle?: string
+  jobName?: string
+  jobId?: string
+  timestamp?: string
+  summary?: string
+  evidence?: string
+  fields: SemanticField[]
+  items: SemanticItem[]
+  links: SemanticField[]
+  actions: SemanticAction[]
+  copyText: string
+}
+
+const FIELD_LABELS = [
+  '缁撹',
+  '璇佹嵁',
+  '鏄庣粏',
+  '浜嬩欢',
+  '涓轰粈涔堥噸瑕?,
+  '鎬庝箞澶勭悊/璺熻繘',
+  '鎬庝箞澶勭悊',
+  '璺熻繘',
+  '閾炬帴',
+  '寤鸿',
+  '绫诲瀷',
+  '閿欒',
+  '寮傚父瀛楁',
+  '鏈€杩戣繍琛?,
+]
+
+const FIELD_LABEL_PATTERN = FIELD_LABELS
+  .map(label => label.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'))
+  .join('|')
+
+function cleanValue(value: string): string {
+  return value
+    .replace(/\s+/g, ' ')
+    .replace(/^[锛?锛?銆俓s]+/, '')
+    .replace(/[锛?锛?\s]+$/, '')
+    .trim()
+}
+
+function stripFooter(text: string): string {
+  return text
+    .replace(/To stop or manage this job[\s\S]*$/i, '')
+    .replace(/濡傞渶鍋滄鎴栫鐞嗘浠诲姟[\s\S]*$/i, '')
+    .trim()
+}
+
+function parseInlineFields(text: string): SemanticField[] {
+  const regex = new RegExp(`(${FIELD_LABEL_PATTERN})[锛?]\\s*`, 'g')
+  const matches = [...text.matchAll(regex)]
+  if (matches.length === 0) return []
+
+  const fields: SemanticField[] = []
+  for (const [index, match] of matches.entries()) {
+    const label = match[1]
+    const start = (match.index || 0) + match[0].length
+    const end = index + 1 < matches.length ? matches[index + 1].index || text.length : text.length
+    const value = cleanValue(text.slice(start, end))
+    if (value) fields.push({ label, value, mono: isTechnicalField(label, value), href: firstUrl(value) })
+  }
+  return fields
+}
+
+function fieldMap(fields: SemanticField[]): Map<string, SemanticField> {
+  return new Map(fields.map(field => [field.label, field]))
+}
+
+function cleanUrl(url: string): string {
+  return url.replace(/[.,;:!?锛屻€傦紱锛氾紒锛熴€侊級\]銆戙€媇+$/u, '')
+}
+
+function firstUrl(text: string): string | undefined {
+  const raw = text.match(/https?:\/\/[^\s)]+/i)?.[0]
+  return raw ? cleanUrl(raw) : undefined
+}
+
+function uniqueLinks(fields: SemanticField[], source: string): SemanticField[] {
+  const urls = new Set<string>()
+  for (const field of fields) {
+    if (field.href) urls.add(field.href)
+  }
+  for (const url of source.match(/https?:\/\/[^\s)]+/gi) || []) {
+    urls.add(cleanUrl(url))
+  }
+  return [...urls].map((url, index) => ({
+    label: index === 0 ? '閾炬帴' : `閾炬帴 ${index + 1}`,
+    value: url,
+    href: url,
+  }))
+}
+
+function isTechnicalField(label: string, value: string): boolean {
+  return (
+    label === '寮傚父瀛楁' ||
+    label === '鏈€杩戣繍琛? ||
+    label === '绫诲瀷' ||
+    label === '閿欒' ||
+    /^(last_status|HTTP|RuntimeError|[A-Za-z]:\\)/.test(value)
+  )
+}
+
+function extractTimestamp(text: string): string | undefined {
+  return text.match(/\d{4}-\d{2}-\d{2}(?:[T\s]\d{2}:\d{2}(?::\d{2}(?:\.\d+)?)?(?:[+-]\d{2}:\d{2})?)?/)?.[0]
+}
+
+function collectBulletItems(lines: string[]): string[] {
+  const items: string[] = []
+  let current = ''
+
+  for (const rawLine of lines) {
+    const line = rawLine.trim()
+    if (!line) continue
+    if (/^[鈥?-]\s+/.test(line)) {
+      if (current) items.push(current)
+      current = line.replace(/^[鈥?-]\s+/, '').trim()
+      continue
+    }
+    if (current && !/^[-]{3,}$/.test(line)) {
+      current += ` ${line}`
+    }
+  }
+
+  if (current) items.push(current)
+  return items
+}
+
+function parseItems(lines: string[]): SemanticItem[] {
+  return collectBulletItems(lines).map(raw => {
+    const fields = parseInlineFields(raw)
+    const firstFieldIndex = fields.length > 0
+      ? raw.search(new RegExp(`(${FIELD_LABEL_PATTERN})[锛?]`))
+      : -1
+    const titleRaw = firstFieldIndex >= 0 ? raw.slice(0, firstFieldIndex) : raw
+    const id = titleRaw.match(/\(([^)]+)\)/)?.[1]
+    const title = cleanValue(titleRaw.replace(/\([^)]+\)/, '')) || '鏄庣粏'
+    return { title, id, fields }
+  })
+}
+
+function inferCronReportTone(preface: string, body: string, title: string): SemanticMessageTone {
+  const report = `${title}\n${body}`
+  if (/^\s*(?:鉂孿s*)?(?:Cron\s+job|浠诲姟)\b.*(?:failed|failure|errored|鎵ц澶辫触)/i.test(body)) return 'danger'
+  if (/\b(?:RuntimeError|Traceback|Bad Gateway)\b|HTTP\s*5\d\d/i.test(body)) return 'danger'
+  if (/last_status\s*=\s*error/i.test(body)) return 'danger'
+  if (/鍛婅|寮傚父瀛楁|闇€瑕佸叧娉▅鐪嬭捣鏉ユ病杩愯|鏈€佽揪|鎶曢€掑紓甯竱warning|warn|娉ㄦ剰/i.test(report)) return 'warning'
+  if (/^\s*鉁厊鎴愬姛|瀹屾垚/.test(body) || /^\s*鉁?.test(preface)) return 'success'
+  if (/鎻愰啋|浜嬩欢|閾炬帴/.test(report)) return 'info'
+  return 'info'
+}
+
+function toneStatus(tone: SemanticMessageTone, source: string, title: string): string {
+  if (tone === 'success') return '瀹屾垚'
+  if (tone === 'danger') return /鍛婅|last_status\s*=\s*error|寮傚父瀛楁/i.test(title + source) ? '寮傚父' : '澶辫触'
+  if (tone === 'warning') return '鍛婅'
+  return /鎻愰啋|浜嬩欢/.test(title + source) ? '鎻愰啋' : '淇℃伅'
+}
+
+function toneIcon(tone: SemanticMessageTone): string {
+  if (tone === 'success') return '鉁?
+  if (tone === 'danger') return '!'
+  if (tone === 'warning') return '!'
+  return 'i'
+}
+
+function buildCopyText(card: Omit<SemanticMessageCard, 'copyText'>): string {
+  const lines = [
+    `${card.status} ${card.title}`,
+    card.summary ? `缁撹锛?{card.summary}` : '',
+    card.evidence ? `璇佹嵁锛?{card.evidence}` : '',
+    card.jobId ? `job_id锛?{card.jobId}` : '',
+  ].filter(Boolean)
+
+  for (const item of card.items) {
+    const fields = item.fields.map(field => `${field.label}锛?{field.value}`).join('锛?)
+    lines.push(`- ${item.title}${item.id ? ` (${item.id})` : ''}${fields ? `锛?{fields}` : ''}`)
+  }
+
+  return lines.join('\n')
+}
+
+const GENERIC_REPLY_SIGNAL = /(review-only|澶嶆牳|寰呭鎵箌鎵瑰噯鍙戝竷|鏆傜紦|宸叉敹鍙灏氭湭鍙戝竷|鏂癨s*L2)/i
+const LEADING_MARKER = /^\s*(?:[-*]\s*|\d{1,2}[.銆乚\s*)/
+
+function cleanGenericText(value: string): string {
+  return value
+    .replace(/\*\*/g, '')
+    .replace(/`/g, '')
+    .replace(/^[\s\-_*#锛?锛?銆?]*/u, '')
+    .replace(/[\s锛?锛?銆?]*$/u, '')
+    .replace(/\s+/g, ' ')
+    .trim()
+}
+
+function cleanOptionLabel(value: string): string {
+  return cleanGenericText(value)
+    .replace(/^鎴朶s*/u, '')
+    .replace(/鏆傜紦\s*缁х画\s*review-only/iu, '鏆傜紦锛岀户缁?review-only')
+    .replace(/鏆傜紦[,锛宂?\s*review-only/iu, '鏆傜紦锛岀户缁?review-only')
+}
+
+function uniquePush(values: string[], value: string) {
+  const cleaned = cleanGenericText(value)
+  if (cleaned && !values.includes(cleaned)) values.push(cleaned)
+}
+
+function parseGenericOptions(text: string): string[] {
+  const labels: string[] = []
+  const numbered = text.matchAll(/^\s*(?:[-*]\s*)?\d{1,2}[.銆乚\s*((?:鎵瑰噯鍙戝竷|鏆傜紦)[^\n]+?)\s*$/gim)
+  for (const match of numbered) {
+    const label = cleanOptionLabel(match[1])
+    if (label) labels.push(label)
+  }
+
+  const approve = text.match(/鎵瑰噯鍙戝竷\s*([^锛?銆傦紱;\n]+)/i)?.[1]
+  if (approve) labels.push(`鎵瑰噯鍙戝竷 ${cleanGenericText(approve)}`)
+
+  const defer = text.match(/鏆傜紦(?:[锛?]?\s*)?(?:(?:缁х画|淇濇寔)\s*)?(review-only|[^锛?銆傦紱;\n]*)/i)?.[1]
+  if (defer !== undefined) {
+    const target = cleanGenericText(defer) || 'review-only'
+    labels.push(target.toLowerCase() === 'review-only' ? '鏆傜紦锛岀户缁?review-only' : `鏆傜紦锛?{target}`)
+  }
+
+  const seen = new Set<string>()
+  return labels
+    .map(cleanOptionLabel)
+    .filter(label => {
+      const key = label.toLowerCase()
+      if (!label || seen.has(key)) return false
+      seen.add(key)
+      return true
+    })
+    .slice(0, 6)
+}
+
+function parseGenericStatusItems(text: string): string[] {
+  const items: string[] = []
+  for (const rawLine of text.split('\n')) {
+    const line = cleanGenericText(rawLine.replace(LEADING_MARKER, ''))
+    if (!line) continue
+    if (/^(寰呭鎵归」|寰呯‘璁ら」)/.test(line)) {
+      uniquePush(items, '闇€瑕佹壒鍑嗗悗鎵嶈繘鍏ュ彂甯冨姩浣?)
+      continue
+    }
+    if (/鎵瑰噯鍙戝竷|鏆傜紦/.test(line)) continue
+    if (/(宸叉敹鍙灏氭湭鍙戝竷|鏈彂甯億宸插畬鎴恷寰呭彂甯億review-only|鏂癨s*L2)/i.test(line)) {
+      uniquePush(items, line)
+    }
+  }
+  if (!items.length && /寰呭鎵?.test(text)) uniquePush(items, '闇€瑕佹壒鍑嗗悗鎵嶈繘鍏ュ彂甯冨姩浣?)
+  return items
+}
+
+function extractGenericField(text: string, label: string): string | undefined {
+  const escaped = label.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
+  const match = text.match(new RegExp(`(?:^|\\n)\\s*${escaped}[锛?]\\s*([^\\n]+)`, 'i'))
+  return match ? cleanGenericText(match[1]) : undefined
+}
+
+function classifyGenericSemanticMessage(content: string): SemanticMessageCard | null {
+  if (!GENERIC_REPLY_SIGNAL.test(content)) return null
+
+  const options = parseGenericOptions(content)
+  const hasOptionContext = /(寰呭鎵箌璇烽€夋嫨|鍙€墊鎵瑰噯鍙戝竷|鏆傜紦)/i.test(content)
+  if (options.length > 0 && !hasOptionContext) return null
+
+  const statusItems = parseGenericStatusItems(content)
+  const summary = extractGenericField(content, '缁撹')
+    || (statusItems.length >= 2 ? statusItems.slice(0, 2).join('锛?) : statusItems[0])
+  const evidence = extractGenericField(content, '璇佹嵁') || extractGenericField(content, '渚濇嵁')
+
+  if (!options.length && !statusItems.length && !summary) return null
+  if (!options.length && !/(澶嶆牳|review-only)/i.test(content)) return null
+
+  const cardWithoutCopy: Omit<SemanticMessageCard, 'copyText'> = {
+    type: options.length ? 'approval' : 'review',
+    tone: options.length ? 'warning' : 'success',
+    icon: options.length ? '!' : '鉁?,
+    status: options.length ? '寰呯‘璁? : '瀹屾垚',
+    title: /(澶嶆牳|review-only|宸叉敹鍙鏂癨s*L2)/i.test(content) ? '鏈疆澶嶆牳瀹屾垚' : '闇€瑕佺‘璁?,
+    summary,
+    evidence,
+    fields: [],
+    items: statusItems.map(item => ({ title: item, fields: [] })),
+    links: [],
+    actions: [
+      ...options.map(label => ({ label, kind: 'send' as const, value: label })),
+      { label: '澶嶅埗鎽樿', kind: 'copy' as const },
+    ],
+  }
+
+  return {
+    ...cardWithoutCopy,
+    copyText: buildCopyText(cardWithoutCopy),
+  }
+}
+
+
+export function classifySemanticMessage(content: string): SemanticMessageCard | null {
+  const normalized = content.replace(/\r\n/g, '\n').trim()
+  const headerMatch = normalized.match(/Cronjob Response:\s*(.+?)(?:\s*\(job_id:\s*([^)]+)\))?\s*(?:\n|$)/i)
+  if (!headerMatch || headerMatch.index === undefined) {
+    return classifyGenericSemanticMessage(normalized)
+  }
+
+  const preface = normalized.slice(0, headerMatch.index).trim()
+  const jobName = cleanValue(headerMatch[1])
+  const jobId = headerMatch[2]?.trim()
+  const afterHeader = normalized.slice(headerMatch.index + headerMatch[0].length)
+  const withoutFooter = stripFooter(afterHeader)
+  const lines = withoutFooter
+    .split('\n')
+    .map(line => line.trim())
+    .filter(line => line && !/^[-]{3,}$/.test(line))
+
+  const titleLine = lines.find(line => !/^[鈥?-]\s+/.test(line))
+  const topLevelLines = lines.filter(line => !/^[鈥?-]\s+/.test(line))
+  const titleParts = titleLine?.split('|').map(part => part.trim()).filter(Boolean) || []
+  const parsedTitle = titleParts[0]
+  const title = parsedTitle && parsedTitle === jobName ? parsedTitle : jobName || parsedTitle || 'Cron 浠诲姟'
+  const titleTail = titleParts.slice(1).join(' ')
+  const body = lines.join('\n')
+  const fields = parseInlineFields(topLevelLines.join('\n'))
+  const fieldsByLabel = fieldMap(fields)
+  const items = parseItems(lines)
+  const links = uniqueLinks(fields, body)
+  const tone = inferCronReportTone(preface, body, title)
+  const summary = fieldsByLabel.get('缁撹')?.value || fieldsByLabel.get('浜嬩欢')?.value
+  const evidence = fieldsByLabel.get('璇佹嵁')?.value
+  const timestamp = extractTimestamp(titleTail) || extractTimestamp(body)
+  const actionValue = `stop reminder ${jobName || title}`.trim()
+
+  const primaryFields = fields.filter(field =>
+    !['缁撹', '璇佹嵁', '鏄庣粏', '浜嬩欢', '閾炬帴'].includes(field.label) &&
+    !links.some(link => link.value === field.value)
+  )
+
+  const cardWithoutCopy: Omit<SemanticMessageCard, 'copyText'> = {
+    type: 'cron',
+    tone,
+    icon: toneIcon(tone),
+    status: toneStatus(tone, `${preface}\n${body}`, title),
+    title,
+    subtitle: jobName && jobName !== title ? jobName : undefined,
+    jobName,
+    jobId,
+    timestamp,
+    summary,
+    evidence,
+    fields: primaryFields,
+    items,
+    links,
+    actions: [
+      { label: '鏌ョ湅浠诲姟', kind: 'jobs', href: '#/hermes/jobs' },
+      { label: '澶嶅埗鍋滅敤鍙ｄ护', kind: 'stop', value: actionValue },
+      { label: '澶嶅埗鎽樿', kind: 'copy' },
+    ],
+  }
+
+  return {
+    ...cardWithoutCopy,
