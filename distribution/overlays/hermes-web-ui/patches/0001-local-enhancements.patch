+    min-width: 0;
+    max-width: 100%;
+    padding: 5px 8px;
+    border: 1px solid rgba(var(--semantic-rgb), 0.28);
+    border-radius: 6px;
+    background: rgba(var(--semantic-rgb), 0.06);
+    color: var(--semantic-color);
+    font-size: 12px;
+    line-height: 1.45;
+    text-decoration: none;
+    overflow: hidden;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+
+    &:hover {
+      background: rgba(var(--semantic-rgb), 0.1);
+    }
+  }
+}
+
+.semantic-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  padding: 12px 14px 14px;
+}
+
+.semantic-action {
+  min-height: 34px;
+  padding: 0 11px;
+  border: 1px solid $border-color;
+  border-radius: 6px;
+  background: $bg-card;
+  color: $text-primary;
+  font-size: 12px;
+  cursor: pointer;
+  transition: background-color $transition-fast, border-color $transition-fast, color $transition-fast;
+
+  &:hover {
+    border-color: var(--semantic-color);
+    background: $bg-card-hover;
+    color: var(--semantic-color);
+  }
+
+  &:focus-visible {
+    outline: 2px solid rgba(var(--semantic-rgb), 0.45);
+    outline-offset: 2px;
+  }
+
+  &.jobs {
+    border-color: rgba(var(--semantic-rgb), 0.4);
+    color: var(--semantic-color);
+  }
+
+  &.send {
+    border-color: rgba(var(--semantic-rgb), 0.48);
+    background: rgba(var(--semantic-rgb), 0.1);
+    color: var(--semantic-color);
+    font-weight: 650;
+  }
+}
+
+@media (max-width: $breakpoint-mobile) {
+  .semantic-title-line {
+    align-items: flex-start;
+  }
+
+  .semantic-status {
+    margin-top: 1px;
+  }
+
+  .semantic-summary-row,
+  .semantic-item-field {
+    grid-template-columns: 1fr;
+    gap: 3px;
+  }
+
+  .semantic-fields {
+    grid-template-columns: 1fr;
+  }
+
+  .semantic-actions {
+    display: grid;
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .semantic-action {
+    min-height: 40px;
+  }
+}
+</style>
