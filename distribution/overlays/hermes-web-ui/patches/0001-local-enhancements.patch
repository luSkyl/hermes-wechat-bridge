+<script setup lang="ts">
+import type { SemanticAction, SemanticMessageCard as SemanticMessageCardModel } from "@/utils/semantic-message";
+
+defineProps<{
+  card: SemanticMessageCardModel;
+}>();
+
+const emit = defineEmits<{
+  action: [action: SemanticAction];
+}>();
+
+function formatSemanticLink(url: string): string {
+  try {
+    const parsed = new URL(url);
+    const path = parsed.pathname
+      .split("/")
+      .filter(Boolean)
+      .slice(0, 2)
+      .join("/");
+    return path ? `${parsed.hostname}/${path}` : parsed.hostname;
+  } catch {
+    return url;
+  }
+}
+</script>
+
+<template>
+  <div class="semantic-card" :class="card.tone">
+    <div class="semantic-head">
+      <div class="semantic-title-wrap">
+        <span class="semantic-icon" aria-hidden="true">{{ card.icon }}</span>
+        <div class="semantic-title-stack">
+          <div class="semantic-title-line">
+            <span class="semantic-title">{{ card.title }}</span>
+            <span class="semantic-status">{{ card.status }}</span>
+          </div>
+          <div v-if="card.subtitle || card.timestamp || card.jobId" class="semantic-subtitle">
+            <span v-if="card.subtitle">{{ card.subtitle }}</span>
+            <span v-if="card.timestamp">{{ card.timestamp }}</span>
+            <code v-if="card.jobId">job {{ card.jobId }}</code>
+          </div>
+        </div>
+      </div>
+    </div>
+
+    <div v-if="card.summary || card.evidence" class="semantic-summary">
+      <div v-if="card.summary" class="semantic-summary-row">
+        <span class="semantic-summary-label">缁撹</span>
+        <span>{{ card.summary }}</span>
+      </div>
+      <div v-if="card.evidence" class="semantic-summary-row">
+        <span class="semantic-summary-label">璇佹嵁</span>
+        <span>{{ card.evidence }}</span>
+      </div>
+    </div>
+
+    <div v-if="card.fields.length" class="semantic-fields">
+      <div
+        v-for="(field, fieldIndex) in card.fields"
+        :key="`${field.label}-${fieldIndex}`"
+        class="semantic-field"
+      >
+        <span class="semantic-field-label">{{ field.label }}</span>
+        <a v-if="field.href" :href="field.href" target="_blank" rel="noreferrer" class="semantic-field-value link">
+          {{ formatSemanticLink(field.href) }}
+        </a>
+        <code v-else-if="field.mono" class="semantic-field-value mono">{{ field.value }}</code>
+        <span v-else class="semantic-field-value">{{ field.value }}</span>
+      </div>
+    </div>
+
+    <div v-if="card.items.length" class="semantic-items">
+      <div
+        v-for="(item, itemIndex) in card.items"
+        :key="`${item.title}-${itemIndex}`"
+        class="semantic-item"
+      >
+        <div class="semantic-item-head">
+          <span class="semantic-item-title">{{ item.title }}</span>
+          <code v-if="item.id" class="semantic-item-id">{{ item.id }}</code>
+        </div>
+        <div v-if="item.fields.length" class="semantic-item-fields">
+          <div
+            v-for="(field, fieldIndex) in item.fields"
+            :key="`${field.label}-${fieldIndex}`"
+            class="semantic-item-field"
+          >
+            <span class="semantic-item-label">{{ field.label }}</span>
+            <a v-if="field.href" :href="field.href" target="_blank" rel="noreferrer" class="semantic-item-value link">
+              {{ formatSemanticLink(field.href) }}
+            </a>
+            <code v-else-if="field.mono" class="semantic-item-value mono">{{ field.value }}</code>
+            <span v-else class="semantic-item-value">{{ field.value }}</span>
+          </div>
+        </div>
+      </div>
+    </div>
+
+    <div v-if="card.links.length" class="semantic-links">
+      <a
+        v-for="(link, linkIndex) in card.links"
+        :key="`${link.value}-${linkIndex}`"
+        :href="link.href"
+        target="_blank"
+        rel="noreferrer"
+      >
+        {{ formatSemanticLink(link.value) }}
+      </a>
+    </div>
+
+    <div class="semantic-actions">
+      <button
+        v-for="action in card.actions"
+        :key="action.label"
+        type="button"
+        class="semantic-action"
+        :class="action.kind"
