# Copy this file to .env and fill real values locally. Do not commit .env.

# Demo mode does not require real Hermes or WeChat credentials.
BRIDGE_CONFIG=examples/minimal/config.yaml

# WeChat callback verification token. Use a long random value in production.
WECHAT_TOKEN=replace-with-random-token

# Optional WeChat app credentials for real outbound delivery.
WECHAT_APP_ID=replace-with-app-id
WECHAT_APP_SECRET=replace-with-app-secret

# Hermes endpoint for http mode. Leave unset for mock mode.
HERMES_ENDPOINT=http://127.0.0.1:8765/messages

# Required when exposing service APIs on non-localhost hosts.
BRIDGE_SERVICE_API_TOKEN=replace-with-local-admin-token
